<!-- BANNER -->
<div class="banner">
    <svg
        viewBox="0 0 1200 220"
        preserveAspectRatio="xMidYMid slice"
        xmlns="http://www.w3.org/2000/svg"
    >
        <defs>
            <linearGradient id="gsky" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#ff8a65"></stop>
                <stop offset="45%" stop-color="#ffcc80"></stop>
                <stop offset="100%" stop-color="#b2dfdb"></stop>
            </linearGradient>
        </defs>
        <rect width="1200" height="220" fill="url(#gsky)"></rect>
        <!-- clouds -->
        <ellipse cx="200" cy="55" rx="60" ry="20" fill="rgba(255,255,255,.55)"
        ></ellipse>
        <ellipse cx="245" cy="46" rx="38" ry="14" fill="rgba(255,255,255,.45)"
        ></ellipse>
        <ellipse cx="700" cy="38" rx="58" ry="17" fill="rgba(255,255,255,.5)"
        ></ellipse>
        <ellipse cx="748" cy="32" rx="36" ry="13" fill="rgba(255,255,255,.42)"
        ></ellipse>
        <ellipse cx="1060" cy="58" rx="52" ry="16" fill="rgba(255,255,255,.48)"
        ></ellipse>
        <!-- ice mountains left -->
        <polygon points="20,200 75,75 130,200" fill="#b0bec5" opacity=".7"
        ></polygon>
        <polygon points="80,200 140,55 200,200" fill="#90a4ae" opacity=".65"
        ></polygon>
        <polygon points="0,200 45,105 90,200" fill="#cfd8dc" opacity=".5"
        ></polygon>
        <!-- ground -->
        <ellipse cx="600" cy="260" rx="750" ry="90" fill="#388e3c" opacity=".65"
        ></ellipse>
        <ellipse cx="220" cy="280" rx="280" ry="70" fill="#2e7d32" opacity=".5"
        ></ellipse>
        <!-- big green hill right -->
        <ellipse
            cx="990"
            cy="215"
            rx="155"
            ry="135"
            fill="#4caf50"
            opacity=".85"></ellipse>
        <ellipse cx="990" cy="200" rx="130" ry="110" fill="#66bb6a"></ellipse>
        <!-- tiny house on hill -->
        <rect
            x="958"
            y="100"
            width="52"
            height="40"
            rx="6"
            fill="#795548"
            opacity=".85"></rect>
        <rect x="968" y="110" width="13" height="13" rx="2" fill="#ffe082"
        ></rect>
        <rect x="987" y="110" width="13" height="13" rx="2" fill="#ffe082"
        ></rect>
        <line x1="996" y1="100" x2="996" y2="70" stroke="#555" stroke-width="2"
        ></line>
        <polygon points="996,70 1014,77 996,84" fill="#e53935"></polygon>
    </svg>
</div>


